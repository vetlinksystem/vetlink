# Copy this file to .env and fill in the values.

# JWT signing secret
SECRET_KEY=change-me

# Set to 'production' on Render (loads the service account from /etc/secrets/sak.json)
# DEV_ENV=production

# ===== Supabase Storage (file/image uploads) =====
# Project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=
# service_role key — SERVER-SIDE ONLY. Never ship this in the Android app.
SUPABASE_SERVICE_KEY=
# Storage bucket name (create it in the Supabase dashboard; make it Public)
SUPABASE_BUCKET=vetlink
